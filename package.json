{
  "name": "mc-retrieval-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Web demo for cross-modal text<->Minecraft voxel schematic retrieval",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export-gallery": "python scripts/export_gallery.py --n 240",
    "build-voxel-assets": "node scripts/build_voxel_assets.mjs",
    "build-text-embeddings": "node scripts/build_text_embeddings.mjs",
    "build-data": "npm run build-voxel-assets && npm run build-text-embeddings",
    "model-precompute": "python model_server/precompute.py",
    "model-server": "python model_server/serve.py"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "hyparquet": "^1.26.1",
    "next": "^15.1.6",
    "prismarine-schematic": "^1.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.172.0",
    "duckdb": "^1.4.4",
    "minecraft-assets": "^1.17.0",
    "minecraft-data": "^3.111.0",
    "prismarine-block": "^1.23.0",
    "prismarine-chunk": "^1.40.0",
    "prismarine-viewer": "^1.33.0",
    "prismarine-world": "^3.7.0",
    "puppeteer-core": "^24.43.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vec3": "^0.2.0"
  }
}
